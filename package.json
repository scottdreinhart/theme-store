{
  "name": "theme-store-service",
  "version": "1.0.0",
  "description": "Theme Store",
  "type": "module",
  "private": true,
  "license": "PROPRIETARY",
  "author": "Scott Reinhart",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": "24.14.0",
    "npm": "11.9.0",
    "pnpm": "10.31.0"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "vite --host",
    "dev": "kill-port 5173 2>/dev/null || true; vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "build:preview": "pnpm build && pnpm preview",
    "lint": "eslint src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "fix": "pnpm eslint:fix && pnpm prettier:fix",
    "validate": "pnpm check && pnpm build",
    "clean": "rimraf dist release",
    "clean:node": "rimraf node_modules",
    "clean:all": "rimraf dist release node_modules",
    "reinstall": "pnpm clean:all && pnpm install",
    "prebuild": "pnpm clean",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:preview": "pnpm build && electron .",
    "cap:init:android": "pnpm exec cap add android",
    "cap:init:ios": "pnpm exec cap add ios",
    "cap:sync": "vite build && pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:run:android": "pnpm exec cap run android",
    "cap:run:ios": "pnpm exec cap run ios",
    "wasm:build": "node scripts/build-wasm.js",
    "wasm:build:debug": "node scripts/build-wasm.js --debug",
    "check:input": "bash scripts/check-input-controls.sh"
  },
  "dependencies": {
    "@capacitor/android": "8.2.0",
    "@capacitor/core": "8.2.0",
    "@esbuild/linux-x64": "0.27.3",
    "@rollup/rollup-linux-x64-gnu": "4.59.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "8.2.0",
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "assemblyscript": "0.28.10",
    "concurrently": "9.2.1",
    "electron": "40.8.0",
    "electron-builder": "26.8.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-boundaries": "5.4.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "kill-port": "2.0.1",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "rollup-plugin-visualizer": "5.14.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "7.3.2",
    "wait-on": "8.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.scottreinhart.themestore",
    "productName": "Theme Store",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
